{% extends './layout.html.twig' %}

{% block title %}{{ pair }} | Trading View | Crypto Bot{% endblock %}

{% block content %}
    <div class="content-wrapper">
        <div id="tradingview"></div>
    </div>
    <script>
        const title = document.title;

        async function  fetchTradeData() {
            const res = await fetch('/api/v1/trade/{{ exchange }}.{{ pair }}');
            const data = await res.json();

            if (!data.ticker) {
                return;
            }

            if (!data.ticker.bid) {
                return;
            }            

            document.title = `${data.ticker.bid} | ${title}`;
        }

        fetchTradeData();
        setInterval(fetchTradeData, 3000);
    </script>
{% endblock %}


{% block javascript %}
<script src="https://s3.tradingview.com/tv.js"></script>
<script>
$('#themeSwitch').on('change', function() {
    if (!$(this).is(':checked') && !$('body').hasClass('dark-mode')) {
        $('#tradingview').empty();
        tradingView('dark');   
    }

    if ($(this).is(':checked') && $('body').hasClass('dark-mode')) {
        $('#tradingview').empty();
        tradingView('light');
    }
});

function tradingView(theme) {
  new TradingView.widget(
    {
      "autosize": true,
      "symbol": "{{ symbol }}",
            "autosize": true,
            "interval": "15",
            "theme": theme,
            "style": "1",
            "locale": "en",
            "toolbar_bg": "#f1f3f6",
            "enable_publishing": false,
            "allow_symbol_change": false,
            "withdateranges": true,
            "hide_side_toolbar": false,
            "details": true,
            "container_id": "tradingview",
            "timezone": Intl.DateTimeFormat().resolvedOptions().timeZone,
            "studies": [
                //"BB@tv-basicstudies",
                //"CCI@tv-basicstudies",
                //"MACD@tv-basicstudies",
                //"MAExp@tv-basicstudies",
                "RSI@tv-basicstudies",
                //"StochasticRSI@tv-basicstudies"
            ],
        }
    );
}

tradingView(localStorage.getItem('darkMode') === 'enabled' ? "dark" : "light");

$(function(){
    var wrapperH = $('.content-wrapper').height();
    $('#tradingview').css('height', (wrapperH)+'px');       
});
</script>
{% endblock javascript %}
