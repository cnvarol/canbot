{% extends './layout.html.twig' %}

{% block title %}{{ pair }} | Trading View | Crypto Bot{% endblock %}

{% block content %}
    <div class="content-wrapper">
        <div id="tradingview" style="width: 100%; height: 600px"></div>
    </div>
    <script>
        const title = document.title;

        async function  fetchTradeData() {
            const res = await fetch('/api/v1/trade/{{ exchange }}.{{ pair }}');
            const data = await res.json();

            if (!('ticker' in data)) {
                return;
            }

            document.title = `${data.ticker.bid} | ${title}`;
        }

        fetchTradeData();
        setInterval(fetchTradeData, 3000);
    </script>
{% endblock %}


{% block javascript %}
<script src="https://s3.tradingview.com/tv.js"></script>
<script>
  new TradingView.widget(
    {
      "autosize": true,
      "symbol": "{{ symbol }}",
            "interval": "15",
            "theme": localStorage.getItem('darkMode') === 'enabled' ? "dark" : "light",
            "style": "1",
            "locale": "en",
            "toolbar_bg": "#f1f3f6",
            "enable_publishing": false,
            "allow_symbol_change": true,
            "container_id": "tradingview",
            "timezone": Intl.DateTimeFormat().resolvedOptions().timeZone,
            "studies": [
                //"BB@tv-basicstudies",
                //"CCI@tv-basicstudies",
                //"MACD@tv-basicstudies",
                //"MAExp@tv-basicstudies",
                "RSI@tv-basicstudies",
                //"StochasticRSI@tv-basicstudies"
            ],
        }
    );
</script>
{% endblock javascript %}
