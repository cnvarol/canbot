{% extends './layout.html.twig' %}

{% block title %}Grid Model | Crypto Bot{% endblock %}

{% block head %}
    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
    <style>
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            /* display: none; <- Crashes Chrome on hover */
            -webkit-appearance: none;
            margin: 0; /* <-- Apparently some margin are still there even though it's hidden */
        }

        input[type=number] {
            -moz-appearance:textfield; /* Firefox */
        }
    </style>
{% endblock %}

{% block content %}
    <!-- Content Wrapper. Contains page content -->
    <div class="content-wrapper">
        <!-- Content Header (Page header) -->
        <section class="content-header">
            <div class="container">
                <div class="row mb-2">
                    <div class="col-sm-6">
                        <h1>Grid Model</h1>
                    </div>
                    <div class="col-sm-6">
                        <ol class="breadcrumb float-sm-right">
                            <li class="breadcrumb-item"><a href="{{ '/' }}">Dashboard</a></li>
                            <li class="breadcrumb-item active">Grid Model</li>
                        </ol>
                    </div>
                </div>
            </div><!-- /.container-fluid -->
        </section>
        <!-- /.Content Header (Page header) -->

        <!-- Main content -->
        <div class="content" id="grid-model">
            <div class="container">
                <div class="row">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-body">
                                <form v-on:submit.prevent>
                                    <div class="row">
                                        <div class="col">
                                            <input type="number" step="0.000001" class="form-control form-control-sm" id="price" placeholder="Price" v-model.number="price" required>
                                        </div>
                                        <div class="col">
                                            <input type="number" step="0.000001" class="form-control form-control-sm" id="amount" placeholder="Amount" v-model.number="amount" required>
                                        </div>
                                        <div class="col">
                                            <input type="number" step="0.000001" class="form-control form-control-sm" id="resolution" placeholder="Position Resolution" v-model.number="resolution" required>
                                        </div>
                                        <div class="col">
                                            <input type="number" step="0.000001" class="form-control form-control-sm" id="hedgeResolution" placeholder="Hedge Resolution" v-model.number="hedge_resolution" required>
                                        </div>
                                        <div class="col">
                                            <input type="number" step="0.000001" class="form-control form-control-sm" id="hedgePercent" placeholder="Hedge Percent" v-model.number="hedge_percent" required>
                                        </div>
                                        <div class="col">
                                            <button class="btn btn-primary btn-sm" v-on:click="calculate">Calculate</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12" v-if="short_model.length">
                        <div class="card card-outline card-danger">
                            <div class="card-header border-bottom-0"><h4>Short Model</h4></div>
                            <div class="card-body">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <th>Current Price</th>
                                        <th>Price Changes</th>
                                        <th>Cumulative Changes</th>
                                        <th>Entry Price</th>
                                        <th>Amount</th>
                                        <th>Size</th>
                                        <th>Net Profit</th>
                                        <th>Unrealized Profit</th>
                                    </thead>
                                    <tbody>
                                        <tr v-for="model in short_model">
                                            <td>[[ model.price | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.changes > 0, 'text-danger': model.changes < 0 }">[[ model.changes | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.cumulative > 0, 'text-danger': model.cumulative < 0 }">[[ model.cumulative | round(2)  ]]%</span></td>
                                            <td>[[ model.entry | filter_price ]] <small>USDT</small></td>
                                            <td>[[ model.amount ]]</td>
                                            <td>[[ model.size | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.net_pnl > 0, 'text-danger': model.net_pnl < 0 }">[[ model.net_pnl | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.unrealized_pnl > 0, 'text-danger': model.unrealized_pnl < 0 }">[[ model.unrealized_pnl | filter_price ]] <small>USDT</small></span></td>
                                        </tr>
                                    <tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12" v-if="long_model.length">
                        <div class="card card-outline card-success">
                            <div class="card-header border-bottom-0"><h4>Long Model</h4></div>
                            <div class="card-body">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <th>Current Price</th>
                                        <th>Price Changes</th>
                                        <th>Cumulative Changes</th>
                                        <th>Entry Price</th>
                                        <th>Amount</th>
                                        <th>Size</th>
                                        <th>Net Profit</th>
                                        <th>Unrealized Profit</th>
                                    </thead>
                                    <tbody>
                                        <tr v-for="model in long_model">
                                            <td>[[ model.price | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.changes > 0, 'text-danger': model.changes < 0 }">[[ model.changes | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.cumulative > 0, 'text-danger': model.cumulative < 0 }">[[ model.cumulative | round(2)  ]]%</span></td>
                                            <td>[[ model.entry | filter_price ]] <small>USDT</small></td>
                                            <td>[[ model.amount ]]</td>
                                            <td>[[ model.size | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.net_pnl > 0, 'text-danger': model.net_pnl < 0 }">[[ model.net_pnl | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.unrealized_pnl > 0, 'text-danger': model.unrealized_pnl < 0 }">[[ model.unrealized_pnl | filter_price ]] <small>USDT</small></span></td>
                                        </tr>
                                    <tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12" v-if="short_hedge_model.length">
                        <div class="card card-outline card-danger">
                            <div class="card-header border-bottom-0"><h4>Short Hedge Model</h4></div>
                            <div class="card-body">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <th>Current Price</th>
                                        <th>Price Changes</th>
                                        <th>Cumulative Changes</th>
                                        <th>Entry Price</th>
                                        <th>Amount</th>
                                        <th>Size</th>
                                        <th>Net Profit</th>
                                        <th>Unrealized Profit</th>
                                    </thead>
                                    <tbody>
                                        <tr v-for="model in short_hedge_model">
                                            <td>[[ model.price | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.changes > 0, 'text-danger': model.changes < 0 }">[[ model.changes | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.cumulative > 0, 'text-danger': model.cumulative < 0 }">[[ model.cumulative | round(2)  ]]%</span></td>
                                            <td>[[ model.entry | filter_price ]] <small>USDT</small></td>
                                            <td>[[ model.amount ]]</td>
                                            <td>[[ model.size | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.net_pnl > 0, 'text-danger': model.net_pnl < 0 }">[[ model.net_pnl | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.unrealized_pnl > 0, 'text-danger': model.unrealized_pnl < 0 }">[[ model.unrealized_pnl | filter_price ]] <small>USDT</small></span></td>
                                        </tr>
                                    <tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12" v-if="long_hedge_model.length">
                        <div class="card card-outline card-success">
                            <div class="card-header border-bottom-0"><h4>Long Hedge Model</h4></div>
                            <div class="card-body">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <th>Current Price</th>
                                        <th>Price Changes</th>
                                        <th>Cumulative Changes</th>
                                        <th>Entry Price</th>
                                        <th>Amount</th>
                                        <th>Size</th>
                                        <th>Net Profit</th>
                                        <th>Unrealized Profit</th>
                                    </thead>
                                    <tbody>
                                        <tr v-for="model in long_hedge_model">
                                            <td>[[ model.price | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.changes > 0, 'text-danger': model.changes < 0 }">[[ model.changes | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.cumulative > 0, 'text-danger': model.cumulative < 0 }">[[ model.cumulative | round(2)  ]]%</span></td>
                                            <td>[[ model.entry | filter_price ]] <small>USDT</small></td>
                                            <td>[[ model.amount ]]</td>
                                            <td>[[ model.size | filter_price ]] <small>USDT</small></td>
                                            <td><span v-bind:class="{ 'text-success': model.net_pnl > 0, 'text-danger': model.net_pnl < 0 }">[[ model.net_pnl | round(2) ]]%</span></td>
                                            <td><span v-bind:class="{ 'text-success': model.unrealized_pnl > 0, 'text-danger': model.unrealized_pnl < 0 }">[[ model.unrealized_pnl | filter_price ]] <small>USDT</small></span></td>
                                        </tr>
                                    <tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <!-- /.content -->
    </div>
<script>
Vue.filter('filter_price', function(value) {
  if (parseFloat(value) > 0 && parseFloat(value) < 1) {
    return Intl.NumberFormat('en-US', {
      useGrouping: false,
      minimumFractionDigits: 2,
      maximumFractionDigits: 5
    }).format(value);
  }

  return Intl.NumberFormat('en-US', {
    useGrouping: false,
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  }).format(value);
});

Vue.filter('round', function(value, decimalPlaces = 0) {
  return parseFloat(value).toFixed(decimalPlaces);
});

var app = new Vue({
  el: '#grid-model',
  delimiters: ['[[', ']]'],
  data: {
    short_model: [],
    long_model: [],
    short_hedge_model: [],
    long_hedge_model: []
  },
  methods: {
    calculate() {
        if (!this.price || !this.amount || !this.resolution || !this.hedge_resolution || !this.hedge_percent) {
            return;
        }

        this.short_model = [];
        this.long_model = [];
        this.short_hedge_model = [];
        this.long_hedge_model = [];

        this.short_model.push({
            price: this.price,
            changes: 0,
            cumulative: 0,
            entry: this.price,
            amount: this.amount,
            size: this.amount*this.price,
            net_pnl: 0,
            unrealized_pnl: 0
        });

        this.long_model.push({
            price: this.price,
            changes: 0,
            cumulative: 0,
            entry: this.price,
            amount: this.amount,
            size: this.amount*this.price,
            net_pnl: 0,
            unrealized_pnl: 0
        });

        this.short_hedge_model.push({
            price: this.price*(1-this.hedge_percent/100),
            changes: 0,
            cumulative: 0,
            entry: this.price*(1-this.hedge_percent/100),
            amount: this.amount,
            size: this.amount*this.price*(1-this.hedge_percent/100),
            net_pnl: 0,
            unrealized_pnl: 0
        });

        this.long_hedge_model.push({
            price: this.price*(1+this.hedge_percent/100),
            changes: 0,
            cumulative: 0,
            entry: this.price*(1+this.hedge_percent/100),
            amount: this.amount,
            size: this.amount*this.price*(1+this.hedge_percent/100),
            net_pnl: 0,
            unrealized_pnl: 0
        });

        // short_model
        for(let i = 0; i < 8; i++) {
            const first_model = this.short_model[0];
            const last_model = this.short_model[this.short_model.length-1];

            const price = last_model.entry * (1 + Math.sqrt(last_model.size / this.resolution) / 100);
            const changes = (price / last_model.price - 1) * 100;
            const cumulative = (price / first_model.price - 1) * 100;
            const entry = (price + last_model.entry) / 2;
            const amount = Math.pow(2, i) * first_model.amount;
            const size = last_model.size + (amount * price);
            const net_pnl = (1 - price / entry) * 100;
            const unrealized_pnl = size * net_pnl / 100;

            this.short_model.push({
                price: price,
                changes: changes,
                cumulative: cumulative,
                entry: entry,
                amount: amount,
                size: size,
                net_pnl: net_pnl,
                unrealized_pnl: unrealized_pnl
            });
        }

        // long_model
        for(let i = 0; i < 8; i++) {
            const first_model = this.long_model[0];
            const last_model = this.long_model[this.long_model.length-1];

            const price = last_model.entry * (1 - Math.sqrt(last_model.size / this.resolution) / 100);
            const changes = (1 - last_model.price / price) * 100;
            const cumulative = (1 - first_model.price / price) * 100;
            const entry = (price + last_model.entry) / 2;
            const amount = Math.pow(2, i) * first_model.amount;
            const size = last_model.size + (amount * price);
            const net_pnl = (price / entry - 1) * 100;
            const unrealized_pnl = size * net_pnl / 100;

            this.long_model.push({
                price: price,
                changes: changes,
                cumulative: cumulative,
                entry: entry,
                amount: amount,
                size: size,
                net_pnl: net_pnl,
                unrealized_pnl: unrealized_pnl
            });
        }

        // short_hedge_model
        for(let i = 0; i < 6; i++) {
            const first_model = this.short_hedge_model[0];
            const last_model = this.short_hedge_model[this.short_hedge_model.length-1];

            const price = last_model.entry * (1 - Math.sqrt(last_model.size / this.hedge_resolution) / 100);
            const changes = (last_model.price / price - 1) * 100;
            const cumulative = (first_model.price / price - 1) * 100;
            const entry = (price + last_model.entry) / 2;
            const amount = Math.pow(2, i) * first_model.amount;
            const size = last_model.size + (amount * price);
            const net_pnl = (1 - price / entry) * 100;
            const unrealized_pnl = size * net_pnl / 100;

            this.short_hedge_model.push({
                price: price,
                changes: changes,
                cumulative: cumulative,
                entry: entry,
                amount: amount,
                size: size,
                net_pnl: net_pnl,
                unrealized_pnl: unrealized_pnl
            });
        }

        // long_hedge_model
        for(let i = 0; i < 6; i++) {
            const first_model = this.long_hedge_model[0];
            const last_model = this.long_hedge_model[this.long_hedge_model.length-1];

            const price = last_model.entry * (1 + Math.sqrt(last_model.size / this.hedge_resolution) / 100);
            const changes = (price / last_model.price - 1) * 100;
            const cumulative = (price / first_model.price - 1) * 100;
            const entry = (price + last_model.entry) / 2;
            const amount = Math.pow(2, i) * first_model.amount;
            const size = last_model.size + (amount * price);
            const net_pnl = (price / entry - 1) * 100;
            const unrealized_pnl = size * net_pnl / 100;

            this.long_hedge_model.push({
                price: price,
                changes: changes,
                cumulative: cumulative,
                entry: entry,
                amount: amount,
                size: size,
                net_pnl: net_pnl,
                unrealized_pnl: unrealized_pnl
            });
        }
    }
  }
})
</script>
{% endblock %}