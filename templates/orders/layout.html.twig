{% extends '../layout.html.twig' %}

{% block title %}Orders | Crypto Bot{% endblock %}

{% block content %}
<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Orders</h1>
                </div>
            </div>
        </div>
    </section>

    <div class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-3">

                    <div class="card card-outline card-teal">
                        <div class="card-header border-bottom-0">
                            <h3 class="card-title">
                                Pairs
                            </h3>

                            <small class="float-sm-right"><input class="filter-pairs form-control form-control-sm" type="text" placeholder="Filter"></small>
                        </div>
                        <div class="card-body">
                            <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                            {% for exchange, list in pairs %}
                                <li class="nav-item exchange-item">
                                    <a href="#" class="nav-link">
                                        <i class="nav-icon fas fa-exchange-alt"></i>
                                        <p>
                                            {{ exchange | capitalizeFirstLetter }}
                                            <i class="right fas fa-angle-left"></i>
                                        </p>
                                    </a>
                                    <ul class="nav nav-treeview">
                                        {% for pair in list %}
                                        <li class="nav-item pair-item">
                                            <a href="/orders/{{ exchange }}.{{ pair }}" class="nav-link">
                                                <i class="far fa-circle nav-icon"></i>
                                                <p>{{ pair }}</p>
                                            </a>
                                        </li>
                                        {% endfor %}
                                    </ul>
                                </li>
                            {% endfor %}
                            </ul>
                            <!-- <ul class="list-unstyled">
                                {% for pair in pairs %}
                                    <li class="pair-item"><a href="/orders/{{ pair|url_encode }}">{{ pair }}</a></li>
                                {% endfor %}
                            </ul> -->
                        </div>
                    </div>
                </div>
                <div class="col-md-9">
                {% block page_content %}{% endblock %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}


{% block javascript %}
    <script>
        // filter pairs
        $(function() {
          var filterTimeout = null;
          $( ".filter-pairs" ).keyup(function() {
            var me = $(this);

            if (filterTimeout != null) {
              clearTimeout(filterTimeout);
            }
            filterTimeout = setTimeout(function() {
              var filter = me.val();

              var card = me.closest('.card');
              if (filter.length === 0) {
                card.find('li.exchange-item').removeClass('menu-open');
                card.find('ul.nav-treeview').hide();
                card.find('li.pair-item').show()
                return;
              }

              card.find('li.exchange-item').addClass('menu-open');
              card.find('ul.nav-treeview').show();
              card.find('li.pair-item').each(function() {
                if ($(this).text().toLowerCase().includes(filter.toLowerCase())) {
                  $(this).show()
                } else {
                  $(this).hide()
                }
              });
            }, 250);
          });
        });
    </script>
{% endblock javascript %}