<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="apple-touch-fullscreen" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="dark-translucent">
    <link rel="apple-touch-icon" href="/img/bitcoin.png"/>
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Crypto Bot">
    <link rel="shortcut icon" sizes="512x512" href="/img/bitcoin.png">
    <link rel="manifest" href="/manifest.json" crossorigin="use-credentials">

    <title>{% block title %}Dashboard | Crypto Bot{% endblock %}</title>

    <link rel="icon" href="/favicon.ico"/>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.11.2/css/all.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="/css/adminlte.css?v={{ asset_version() }}">
    <!-- style -->
    <link rel="stylesheet" href="/css/style.css?v={{ asset_version() }}">

    <script>
        let asset_version = '{{ asset_version() }}';
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js', {
                scope: '.'
            })
            .then(function(registration) {
                console.log('Registration successful, scope is:', registration.scope);
            })
            .catch(function(error) {
                console.log('Service worker registration failed, error:', error);
            });
        }
    </script>
    {% block stylesheet %}{% endblock stylesheet %}

    {% block head %}
    {% endblock head %}
</head>
<body class="hold-transition layout-top-nav layout-navbar-fixed">
<script>
    if (localStorage.getItem('darkMode') === 'enabled') {
        document.body.classList.add('dark-mode');
    }
</script>
<div class="wrapper">
    <!-- Navbar -->
    <nav class="main-header navbar navbar-expand-md navbar-dark navbar-teal border-bottom-0">
        <a href="{{ '/' }}" class="navbar-brand">
            <img src="{{ '/img/bitcoin.svg' }}" alt="Logo" class="brand-image img-circle elevation-1"> Crypto Bot
        </a>
        <button class="navbar-toggler order-1" type="button" data-toggle="collapse" data-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse order-3" id="navbarCollapse">
            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a href="{{ '/' }}" class="nav-link">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a href="{{ '/indicators' }}" class="nav-link">Indicators</a>
                </li>
                <li class="nav-item">
                    <a href="{{ '/trades' }}" class="nav-link">Spot</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="derivativesDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        Derivatives
                    </a>
                    <div class="dropdown-menu" aria-labelledby="derivativesDropdown">
                        <a href="{{ '/binance_futures' }}" class="dropdown-item">Binance USDⓈ-M Futures</a>
                        <a href="{{ '/binance_delivery' }}" class="dropdown-item">Binance COIN-M Futures</a>
                    </div>
                </li>
                <li class="nav-item">
                    <a href="{{ '/pairs' }}" class="nav-link">Pairs</a>
                </li>
                <li class="nav-item">
                    <a href="{{ '/orders' }}" class="nav-link">
                        Orders
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ '/signals' }}" class="nav-link">Signals</a>
                </li>
                <li class="nav-item">
                    <a href="{{ '/quarantine' }}" class="nav-link">
                        Quarantine
                        <sup><span class="badge badge-danger badge-pill badge-navbar hide" id="quarantineCount">0</span></sup>
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="toolsDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        Tools
                    </a>
                    <div class="dropdown-menu" aria-labelledby="toolsDropdown">
                        <a href="{{ '/tools/candles' }}" class="dropdown-item">Candles</a>
                        <a href="{{ '/backtest' }}" class="dropdown-item">Backtest</a>
                        <a href="{{ '/gridmodel' }}" class="dropdown-item">Grid Model</a>
                        <a href="{{ '/logs' }}" class="dropdown-item">Logs</a>
                    </div>
                </li>
                {% set desks = desks() %}
                {% if desks|length > 0 %}
                    <li class="nav-item dropdown">
                        <a id="dropdownSubMenu1" href="#" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="nav-link dropdown-toggle">Desks</a>
                        <ul aria-labelledby="dropdownSubMenu1" class="dropdown-menu border-0 shadow">
                            {% for desk in desks %}
                                <li><a href="/desks/{{ loop.index - 1 }}" class="dropdown-item">{{ desk }} </a></li>
                            {% endfor %}

                            <div class="dropdown-divider"></div>

                            {% for desk in desks %}
                                <li><a href="/desks/{{ loop.index - 1 }}/fullscreen" class="dropdown-item"><i class="fas fa-expand text-sm text-muted"></i> &nbsp; {{ desk }}</a></li>
                            {% endfor %}
                        </ul>
                    </li>
                {% endif %}
            </ul>

            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <!-- <div class="btn-group btn-group-toggle" data-toggle="buttons">
                    <label class="btn bg-light">
                        <input type="radio" name="options" id="lightTheme" autocomplete="off" checked=""><i class="fas fa-sun"></i>
                    </label>
                    <label class="btn bg-dark">
                        <input type="radio" name="options" id="darkTheme" autocomplete="off"><i class="far fa-moon"></i>
                    </label>
                    </div>
                    -->
                    <div class="toggle-switch">
                        <input type="checkbox" class="switch" id="themeSwitch">
                        <svg class="checkbox" xmlns="http://www.w3.org/2000/svg" style="isolation:isolate" viewBox="0 0 168 80">
                        <path class="outer-ring" d="M41.534 9h88.932c17.51 0 31.724 13.658 31.724 30.482 0 16.823-14.215 30.48-31.724 30.48H41.534c-17.51 0-31.724-13.657-31.724-30.48C9.81 22.658 24.025 9 41.534 9z" fill="none" stroke="#233043" stroke-width="3" stroke-linecap="square" stroke-miterlimit="3"/>
                        <path class="is_checked" d="M17 39.482c0-12.694 10.306-23 23-23s23 10.306 23 23-10.306 23-23 23-23-10.306-23-23z"/>
                            <path class="is_unchecked" d="M132.77 22.348c7.705 10.695 5.286 25.617-5.417 33.327-2.567 1.85-5.38 3.116-8.288 3.812 7.977 5.03 18.54 5.024 26.668-.83 10.695-7.706 13.122-22.634 5.418-33.33-5.855-8.127-15.88-11.474-25.04-9.23 2.538 1.582 4.806 3.676 6.66 6.25z"/>
                        </svg>
                    </div>
                </li>
                <li class="nav-item">
                    <a href="{{ '/logout' }}" class="nav-link"><i class="fas fa-sign-out-alt" style="font-size:20px;margin-top:5px"></i></a>
                </li>
            </ul>
        </div>
    </nav>
    <!-- /.navbar -->

    {% block content %}
    {% endblock content %}

    <!-- Main Footer -->
    <footer class="main-footer">
        <!-- To the right -->
        <div class="float-right d-none d-sm-inline">
            v3.0 
            {% set hedge_mode = hedge_mode() %}
            {% if hedge_mode %}
            (Hedge Mode)
            {% endif %}
        </div>
        <!-- Default to the left -->
        Node.js {{ node_version() }} - Memory {{ memory_usage() }} MB - Up {{ uptime() }}
    </footer>
</div>
<!-- ./wrapper -->

<!-- REQUIRED SCRIPTS -->

<!-- jQuery -->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
<!-- Bootstrap 4 -->
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.bundle.min.js"></script>
<!-- AdminLTE App -->
<script src="/js/adminlte.min.js?v={{ asset_version() }}"></script>
<script>
    async function  fetchCountsData() {
        const res = await fetch('/api/v1/counts');
        const data = await res.json();

        if (!data) {
            return;
        }

        $(() => {
            if (data.quarantine > 0) {
                $('#quarantineCount').text(data.quarantine);
                $('#quarantineCount').show();
            }

            if (data.quarantine === 0) {
                $('#quarantineCount').hide();
            }
        });
    }

    fetchCountsData();
    setInterval(fetchCountsData, 60000);

    // Add Active Navigation Class Based on URL to Menu Item
    $(function () {
        let path = window.location.href; // because the 'href' property of the DOM element is the absolute path
        $('#navbarNav ul a').each(function() {
            if (this.href === path) {
                $(this).addClass('active');
            }
        });

        $('#themeSwitch').on('change', function() {
            if (!$(this).is(':checked') && !$('body').hasClass('dark-mode')) {
                localStorage.setItem('darkMode', 'enabled');
                $('body').addClass('dark-mode');
            }

            if ($(this).is(':checked') && $('body').hasClass('dark-mode')) {
                localStorage.setItem('darkMode', 'disabled');
                $('body').removeClass('dark-mode');
            }
        });

        if (localStorage.getItem('darkMode') === 'enabled') {
            $('#themeSwitch').prop('checked', false);
        }

        if (localStorage.getItem('darkMode') === 'disabled') {
            $('#themeSwitch').prop('checked', true);
        }

        if (!localStorage.getItem('darkMode')) {
            $('#themeSwitch').prop('checked', true);
        }
    })
</script>
{% block javascript %}{% endblock javascript %}

</body>
</html>
